{
  "_comment": "正式包只带音乐所需的 reaper 与 perception MCP；通用系统执行服务仅保留在开发仓。stage_pkg.py 打包时把此文件 rename 成 mcp_servers.json。",
  "servers": [
    {
      "name": "reaper",
      "enabled": true,
      "command": "python",
      "args": [
        "${PRISM_HOME}/mcps/reaper-mcp/server/reaper_mcp_server.py"
      ]
    },
    {
      "name": "music-perception",
      "enabled": true,
      "command": "${PRISM_HOME}/mcps/music-perception/music_perception.exe",
      "args": [],
      "env": {
        "GEMINI_BASE_URL": "https://generativelanguage.googleapis.com/v1beta/openai/",
        "GEMINI_MODEL": "gemini-2.5-flash"
      }
    }
  ]
}
