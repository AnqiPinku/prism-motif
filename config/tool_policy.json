{
  "default": "write",
  "tools": {
    "reaper_status": "read",
    "list_tracks": "read",
    "get_midi_notes": "read",
    "list_track_fx": "read",
    "list_fx_presets": "read",
    "list_installed_fx": "read",
    "get_fx_params": "read",
    "analyze_audio": "read",
    "measure_loudness": "read",
    "transcribe_melody": "read",

    "set_tempo": "write",
    "set_time_signature": "write",
    "add_track": "write",
    "update_track": "write",
    "create_midi_item": "write",
    "add_midi_notes": "write",
    "update_midi_note": "write",

    "delete_midi_notes": {"risk": "destructive", "trust": true},
    "replace_midi_notes": {"risk": "destructive", "trust": true},
    "add_track_fx": "write",
    "set_fx_preset": "write",
    "set_fx_param": "write",
    "set_time_selection": "write",
    "add_marker": "write",

    "delete_track": {"risk": "destructive", "trust": true},
    "render_project": "destructive",
    "reaper_call": "execute",
    "run_lua": "execute",
    "batch": {
      "risk": "execute",
      "batch": {
        "project_functions": [
          "get_project_summary",
          "list_tracks",
          "set_tempo",
          "set_time_signature",
          "add_track",
          "update_track",
          "delete_track",
          "create_midi_item",
          "add_midi_notes",
          "get_midi_notes",
          "update_midi_note",
          "delete_midi_notes",
          "replace_midi_notes",
          "add_track_fx",
          "list_track_fx",
          "list_fx_presets",
          "set_fx_preset",
          "get_fx_params",
          "set_fx_param",
          "list_installed_fx",
          "transport",
          "set_time_selection",
          "add_marker",
          "render_project",
          "render_to_wav"
        ],
        "aliases": {
          "get_project_summary": "reaper_status"
        }
      }
    },
    "listen_subjective": "external",

    "run_command": "execute",
    "write_file": "destructive",
    "edit_file": "destructive",
    "move_path": "destructive",
    "delete_path": "destructive",

    "transport": {
      "risk": "write",
      "when": [
        {"argument": "action", "equals": "record", "risk": "record"}
      ]
    },
    "render_to_wav": {
      "risk": "write",
      "when": [
        {"argument": "out_path", "present": true, "risk": "destructive"}
      ]
    }
  }
}
